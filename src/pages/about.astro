---
import Navbar from "@components/Navbar.astro";
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
import OurTeam from "@components/about/OurTeam.astro";
import OurVisionSection from "@components/about/OurVisionSection.astro";
import Corevalues from "@components/Corevalues.astro";
import Faq from "@components/about/Faq.astro";
import SideHeader from "@components/SideHeader.astro";
---

<Layout title="About">
  <Navbar />
  <SideHeader
    side="right"
    page="About"
    text="Our strength lies in the collaboration between our talented teams and esteemed clients. We cultivate a workplace that champions innovation, promotes peak performance, and guarantees client satisfaction."
    heading="Igniting Innovation"
  />
  <OurVisionSection />
  <Corevalues theme="light" btnTheme="black" />
  <OurTeam />
  <Faq />
  <Footer />
</Layout>
