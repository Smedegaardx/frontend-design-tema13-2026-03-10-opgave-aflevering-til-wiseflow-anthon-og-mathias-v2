---
import Logo from "@components/Logo.astro";
import Button from "@components/Button.astro";
---

<header>
  <div class="navbar">
    <Logo />
    <ul>
      <a href="/">Home</a>
      <a href="/case">Case Study</a>
      <a href="/team">Team</a>
      <a href="/about">About</a>
    </ul>
    <button id="login-btn" popovertarget="login-popover">Login</button>
    <div id="login-popover" popover>
      <h2>Dashboard Login</h2>
      <div>
        <label for="email">Email address</label>
        <input type="email" id="email" autocomplete="email" />
      </div>
      <div>
        <label for="password">Password</label>
        <input type="password" id="password" autocomplete="current-password" />
      </div>
      <Button buttonText="Go to dashboard" theme="yellow" />
    </div>
  </div>
</header>
<style>
  @layer components {
    header {
      background-color: var(--color-neutrals-900);
      height: 112px;
    }

    .navbar {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    ul {
      padding: 0;
      display: flex;
      gap: 30px;
    }

    a {
      color: white;
      text-decoration: none;
    }

    p {
      display: inline-block;
    }

    #login-btn {
      border: none;
      text-align: center;
      text-decoration: none;
      display: inline-block;
      padding: 3px 20px;
      margin: 4px 2px;
      border-radius: 42px;
      cursor: pointer;
      font-family: lato;
      max-width: 200px;
      max-height: 60px;
      background-color: var(--color-surface-secondary);
      align-items: center;
    }

    #login-popover {
      position: fixed;
      top: 112px;
      right: 1rem;

      &::backdrop {
        background-color: rgba(0, 0, 0, 0.2);
      }
    }

    @supports (anchor-name: --x) {
      #login-btn {
        anchor-name: --login-btn;
      }

      #login-popover:popover-open {
        position-anchor: --login-btn;
        top: 0px;
        right: 0px;
        position: absolute;
        position-area: bottom span-left;
        border-radius: 20px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        border: none;
        gap: 2rem;

        h2 {
          font-family: cabin;
          font-size: 45px;
        }

        div {
          width: 100%;
        }

        input {
          width: 100%;
          padding: 0.5rem 1rem;
          border-radius: 20px;
        }
      }
    }
  }
</style>
