---
import Button from "./Button.astro";
import CorevaluesCard from "./CorevaluesCard.astro";
const { theme, btnTheme } = Astro.props;
---

<!-- Mangler gitterbaggrund, kig på hero -->
<section data-theme={theme}>
  <article>
    <p class="tag">Growing with our clients</p>
    <h1>Our core values & principles</h1>
    <p class="description">
      Capitalize on low hanging fruit to identify a ballpark value added
      activity beta test. Override the digital divide with additional from
      DevOps.
    </p>
    <div class="btn-wrapper">
      <Button buttonText="Get in Touch" theme={btnTheme} />
    </div>
  </article>
  <div class="card-container">
    <CorevaluesCard theme={theme} />
  </div>
</section>

<style>
  @layer components {
    section {
      padding: 4rem 2rem;
    }

    article {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      gap: 0.75rem 2rem;
      margin-bottom: 2.5rem;
      align-items: start;
    }

    .tag {
      font-size: 0.8125rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      grid-column: 1;
      grid-row: 1;
      margin: 0;
    }

    h1 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 800;
      grid-column: 1;
      grid-row: 2;
      margin: 0;
    }

    .description {
      font-size: 1rem;
      line-height: 1.65;
      grid-column: 1;
      grid-row: 3;
      max-width: 52ch;
      margin: 0;
      opacity: 0.85;
    }

    .btn-wrapper {
      grid-column: 2;
      grid-row: 2 / 4;
      align-self: end;
      justify-self: end;
    }

    .card-container {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    section[data-theme="dark"] {
      background-color: var(--color-ui-primary);
    }

    section[data-theme="dark"] article {
      color: var(--color-neutrals-100);
    }

    section[data-theme="light"] {
      background-color: var(--color-on-ui-primary);
    }

    section[data-theme="light"] article {
      color: var(--color-text);

      .description {
        color: var(--color-text-muted);
      }
    }
    @media (width < 900px) {
      .card-container {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (width < 600px) {
      .card-container {
        grid-template-columns: 1fr;
      }
    }
  }
</style>
