---
import employees from "@data/employees.json";
import DynamicImage from "./helpers/DynamicImage.astro";
import Facebook from "@icons/facebook.svg";
import Instagram from "@icons/instagram.svg";
import "@styles/main.css";

const { employeeId } = Astro.props;
const employee = employees.find((e) => e.id === Number(employeeId));

console.log(employeeId);
console.log(employee);
---

<div class="card">
  <div class="imgContainer">
    {
      employee && (
        <DynamicImage
          imagePath={employee.img}
          altText={employee.name}
          width={400}
          height={400}
        />
      )
    }
    <p class="jobTitle">{employee?.title}</p>
  </div>
  <div class="text">
    <h3>{employee?.name}</h3>
    <p>
      {employee?.description}
    </p>
    <div class="icons">
      <Instagram width={32} height={32} class="my-icon" />
      <Facebook width={32} height={32} class="my-icon" />
    </div>
  </div>
</div>

<style>
  .card {
    .imgContainer {
      display: grid;
      :first-child {
        grid-row: 1;
        grid-column: 1;
        border-radius: 25px;
      }
      .jobTitle {
        background-color: var(--color-ui-primary);
        color: var(--color-on-ui-primary);
        padding: 0.2rem 1.2rem;
        border-radius: 25px;
        text-align: center;
        grid-row: 1;
        grid-column: 1;
        align-self: end;
        align-items: end;
        justify-self: end;
        margin: 15px;
      }
    }
    .text {
      padding: 20px;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      h3 {
        font-size: x-large;
      }
      .icons {
        display: flex;
        flex-direction: row;
        justify-content: center;
        gap: 1rem;
      }
    }
  }
</style>
