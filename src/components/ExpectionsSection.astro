---
import CheckmarkCard from "@components/CheckmarkCard.astro";
import SectionImg from "@data/images/temaopg.webp";
import { Image } from "astro:assets";
---

<section>
  <article>
    <div class="img-wrapper">
      <div class="green-box"></div>
      <div class="img-container">
        <Image src={SectionImg} alt="CEO" />
      </div>
    </div>
    <div class="text-content">
      <p class="tag">We'll work with you</p>
      <h1>What To Expect</h1>
      <p class="details">
        Our collaboration is built on transparency, efficiency, and measurable
        results. Together, we create strategies tailored to your unique needs
        and goals.
      </p>
    </div>
    <div class="card-content">
      <p>test</p>
      <p>test</p>
    </div>
  </article>
</section>
<CheckmarkCard texcontent="test" />

<style>
  @layer components {
    section {
      display: grid;
      grid-template-columns: subgrid;
      padding: 4rem 4rem;

      article {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
      }

      .img-wrapper {
        position: relative;
        grid-column: 1;
        grid-row: 1 / -1;
      }

      .green-box {
        position: absolute;
        top: -20px;
        left: -20px;
        width: 160px;
        height: 130px;
        background-color: #b8f0c0;
        border-radius: 1rem;
        z-index: 0;
      }

      .img-container {
        position: relative;
        border-radius: 2rem;
        overflow: clip;
        z-index: 1;
      }

      .text-content {
        grid-column: 2;
      }
    }
  }
</style>
