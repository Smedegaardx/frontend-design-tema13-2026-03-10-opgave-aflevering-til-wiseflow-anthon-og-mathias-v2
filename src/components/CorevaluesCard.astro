---
import valueData from "@data/coreValues.json";
const { theme } = Astro.props;
---

{
  valueData.values.map(({ icon, title, description }) => (
    <div class="card" data-theme={theme}>
      <div class="icon-wrapper">
        <img src={`/src/icons/${icon}.svg`} alt="" />
      </div>
      <h2>{title}</h2>
      <p>{description}</p>
      <a href="#99" class="read-more">
        Read More &rarr;
      </a>
    </div>
  ))
}

<style>
  .card {
    padding: 2rem;
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card[data-theme="dark"] {
    background-color: var(--color-neutrals-50);
  }

  .card[data-theme="light"] {
    background-color: white;
  }

  .icon-wrapper {
    background-color: var(--color-ui-primary);
    border-radius: 50%;
    padding: 0.75rem;
    height: 52px;
    width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  img {
    filter: invert(1);
    width: 24px;
    height: 24px;
  }

  h2 {
    font-size: 1.125rem;
    color: #0a0a0f;
    margin: 0;
  }

  p {
    font-size: 0.9375rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9375rem;
    color: #0a0a0f;
    text-decoration: none;
    margin-top: auto;
  }

  .read-more:hover {
    gap: 0.5rem;
  }
</style>
