---
import CheckmarkCard from "@components/CheckmarkCard.astro";
import SectionImg from "@data/images/temaopg.webp";
import { Image } from "astro:assets";
---

<section>
  <article>
    <div class="img-wrapper">
      <div class="green-box"></div>
      <div class="img-container">
        <Image src={SectionImg} alt="CEO" />
      </div>
    </div>
    <div class="text-content">
      <p class="tag">We'll work with you</p>
      <h3>What To Expect</h3>
      <p class="details">
        Our collaboration is built on transparency, efficiency, and measurable
        results. Together, we create strategies tailored to your unique needs
        and goals.
      </p>
    </div>
    <div class="card-content">
      <CheckmarkCard
        text="Collaborate to build actionable strategies that drive sustainable growth and
    deliver tangible outcomes."
      />
      <CheckmarkCard
        text="Identify opportunities to optimize processes and implement impactful
          solutions with measurable results."
      />
    </div>
  </article>
</section>

<style>
  @layer components {
    section {
      display: grid;
      grid-template-columns: subgrid;
      padding: 4rem 4rem;

      article {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 2rem;
      }

      .img-wrapper {
        position: relative;
        grid-column: 1;
        grid-row: 1 / -1;
      }

      .green-box {
        position: absolute;
        top: -20px;
        left: -20px;
        width: 160px;
        height: 130px;
        background-color: var(--color-ui-secondary);
        border-radius: 1rem;
        z-index: 0;
      }

      .img-container {
        position: relative;
        border-radius: 2rem;
        overflow: clip;
        z-index: 1;
      }

      .text-content {
        grid-column: 2;
      }

      .card-content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .card {
        display: flex;
        flex-direction: row;
        gap: 1rem;
      }

      .my-icon {
        color: var(--color-ui-secondary-alternative);
      }

      .tag {
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin: 0;
      }

      h3 {
        font-weight: 800;
        margin: 0;
      }

      .description {
        font-size: 1rem;
        line-height: 1.65;
        max-width: 52ch;
        margin: 0;
        opacity: 0.85;
      }
    }
    @media (width < 900px) {
      section article {
        display: block;
      }
      .text-content,
      .card-content {
        margin-block-start: 1rlh;
      }
    }
  }
</style>
