---
const { service } = Astro.props;
import ArrowRight from "@icons/arrow--right.svg";
---

<article>
  <h2>{service.title}</h2>
  <p>{service.description}</p>
  <a href="#0">{service.buttonText} <ArrowRight stroke-width={2.5} /></a>
</article>

<style>
  @layer components {
    article {
      background: var(--color-blue-700-transparent);
      color: var(--color-on-surface-elevated);
      padding: 2rem;
      border-radius: 20px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    a {
      display: inline-flex;
      gap: 0.5ch;
      align-items: center;
      color: var(--color-action);
      font-weight: bold;
      margin-top: auto;
    }
  }
</style>
