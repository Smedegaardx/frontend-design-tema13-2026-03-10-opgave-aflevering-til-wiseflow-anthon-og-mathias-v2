---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
import Button from "@components/Button.astro";
import SideHeader from "@components/SideHeader.astro";
---

<section class="hero">
  <div class="hero-content">
    <h1>Empowering Your Business Growth</h1>
    <p>
      Discover tailored strategies and expert insights to take your business to
      the next level. Let us help you navigate challenges and achieve
      sustainable success.
    </p>
    <div class="hero-buttons">
      <Button buttonText="Book a Meeting" theme="yellow" />
      <Button buttonText="Learn More" theme="hero" />
    </div>
  </div>
  <div class="hero-image">
    <Image src={CEOImage} alt="CEO" />
  </div>
  <Services />
</section>
<style>
  @layer components {
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      grid-template-areas:
        "content image"
        "services services";
    }

    .hero-content {
      grid-area: content;
      padding-block: 5rem 10rem;
      padding-left: 8.5rem;
      padding-right: 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      --grid-color: oklch(from #ffcc4a l c h / 0.18);
      --grid-size: 60px;
      background:
        radial-gradient(
          ellipse farthest-side at 60% 60%,
          #0000 10%,
          #030712 75%
        ),
        conic-gradient(
            from 180deg at 1px 1px,
            var(--grid-color) 75%,
            #0000 0
          ) -1px -1px /
          var(--grid-size) var(--grid-size),
        #030712;
    }

    .hero-image {
      grid-area: image;
      overflow: hidden;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    .hero-buttons {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    p {
      font-size: 1rem;
      line-height: 1.65;
      max-width: 46ch;
      margin-bottom: 1.5rem;
      color: var(--color-on-ui-primary-muted);
    }

    h1 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      width: 12ch;
      margin-bottom: 2rem;
      padding-top: 3rem;
      color: white;
      position: relative;
    }

    h1::after {
      content: "";
      position: absolute;
      bottom: -0.5rem;
      left: -8.5rem;
      width: 120%;
      height: 5px;
      background: #ffcc4a;
      background-image: linear-gradient(
        to right,
        black,
        rgba(0, 128, 128, 0) 150px
      );
    }
    @media (width > 900px) {
      :global(.services) {
        grid-area: services;
        margin-block-start: -8rem;
        position: relative;
        z-index: 1;
      }
    }

    @media (width < 900px) {
      .hero {
        display: block;
      }
      .hero-content {
        padding: 3rem;
        h1 {
          width: auto;
          &::after {
            background-image: linear-gradient(
              to right,
              black,
              rgba(0, 128, 128, 0) 300px
            );
          }
        }
        .hero-buttons {
          justify-content: center;
        }
      }
    }
  }
</style>
